        </mxCell>
        <mxCell id="core1" parent="1" style="swimlane;startSize=30;html=1;whiteSpace=wrap;fillColor=#f0f4fb;strokeColor=#6c8ebf;fontStyle=1;verticalAlign=top;" value="CORE 1 — Flight-critical (real-time, no Wi-Fi)" vertex="1">
