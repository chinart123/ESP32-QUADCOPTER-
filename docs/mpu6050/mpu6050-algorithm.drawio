<?xml version="1.0" encoding="UTF-8"?>
<mxfile host="drawio" version="26.0.0">
  <diagram name="MPU6050-Algorithm">
    <mxGraphModel dx="1200" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="title" value="MPU6050 — IMU Algorithm, Attitude Estimation &amp; Cascaded Attitude PID" style="text;html=1;align=center;verticalAlign=middle;fontStyle=1;fontSize=17;" vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="1080" height="30" as="geometry" />
        </mxCell>

        <!-- main sensing pipeline (green) -->
        <mxCell id="config" value="MPU6050 config — begin()&#xa;DLPF 10 Hz  ·  Gyro ±500 dps (÷65.5)  ·  Accel ±8 g (÷4096)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="320" y="60" width="480" height="70" as="geometry" />
        </mxCell>
        <mxCell id="read" value="readBurst() — 14-byte I²C @ 400 kHz&#xa;ax ay az | gx gy gz" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="320" y="170" width="480" height="60" as="geometry" />
        </mxCell>
        <mxCell id="angles" value="Accel → tilt angles (atan2, deg)&#xa;getRawRollAngle · getRawPitchAngle&#xa;Gyro rates getGyroX/Y/Z (− offsets)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="320" y="270" width="480" height="80" as="geometry" />
        </mxCell>
        <mxCell id="attitude" value="ATTITUDE ESTIMATION  (dt = 4 ms)&#xa;Kalman filter (Roll &amp; Pitch)  →  fRoll, fPitch&#xa;Yaw: rawGyroZ − dynamicYawBias (slow learn) → gz_filtered (LPF 0.89/0.11) → integrate fYaw" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="320" y="390" width="480" height="90" as="geometry" />
        </mxCell>
        <mxCell id="outer" value="OUTER loop — Angle P&#xa;tarRate = PAngle · (target − fAngle)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="320" y="530" width="480" height="70" as="geometry" />
        </mxCell>
        <mxCell id="inner" value="INNER loop — Rate PID  (Roll &amp; Pitch)&#xa;err = tarRate − gyro&#xa;out = PRate·err  +  I (iTerm, clamp ±200)  +  D·Δerr/dt&#xa;(I reset when throttle &lt; 50)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="320" y="650" width="480" height="110" as="geometry" />
        </mxCell>
        <mxCell id="mix" value="MOTOR MIX (X-quad) — base throttle ± PID terms&#xa;FL = base − outPitch + outRoll + outYaw&#xa;FR = base − outPitch − outRoll − outYaw&#xa;RL = base + outPitch + outRoll − outYaw&#xa;RR = base + outPitch − outRoll + outYaw&#xa;constrain 30..1023 → ledcWrite (only if armed)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;" vertex="1" parent="1">
          <mxGeometry x="320" y="810" width="480" height="130" as="geometry" />
        </mxCell>

        <!-- side notes -->
        <mxCell id="calib" value="smartCalibrate()&#xa;2000 stable samples (gyro &lt; 15)&#xa;→ pitchOffset, rollOffset,&#xa;yawGyroOffset, gyroX/Y offset" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="265" width="240" height="90" as="geometry" />
        </mxCell>
        <mxCell id="setp" value="Setpoints (from RC)&#xa;targetR / targetP  ±25°&#xa;+ pos-hold add  ±12°&#xa;yaw stick rate  ±150°/s" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="1">
          <mxGeometry x="40" y="530" width="240" height="110" as="geometry" />
        </mxCell>
        <mxCell id="yawpid" value="Yaw rate PID&#xa;err = stickYawRate − gz_filtered&#xa;out = PRateYaw·err + iTermYaw + 0.0028·Δ&#xa;→ outYaw" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="850" y="650" width="270" height="110" as="geometry" />
        </mxCell>

        <!-- edges -->
        <mxCell id="m1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="config" target="read"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="m2" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="read" target="angles"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="m3" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="angles" target="attitude"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="m4" value="fRoll / fPitch (feedback)" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;fontSize=11;labelBackgroundColor=#ffffff;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="attitude" target="outer"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="m5" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="outer" target="inner"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="m6" value="outRoll / outPitch" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;fontSize=11;labelBackgroundColor=#ffffff;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="inner" target="mix"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="m7" value="offsets" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;fontSize=11;labelBackgroundColor=#ffffff;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="calib" target="angles"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="m8" value="target" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;fontSize=11;labelBackgroundColor=#ffffff;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="setp" target="outer"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="m9" value="fYaw / gz_filtered" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;fontSize=11;labelBackgroundColor=#ffffff;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="attitude" target="yawpid">
          <mxGeometry relative="1" as="geometry">
            <Array as="points"><mxPoint x="985" y="435" /></Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="m10" value="outYaw" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;fontSize=11;labelBackgroundColor=#ffffff;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=1;entryY=0.4;entryDx=0;entryDy=0;" edge="1" parent="1" source="yawpid" target="mix"><mxGeometry relative="1" as="geometry" /></mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
