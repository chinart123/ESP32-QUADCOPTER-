        </mxCell>
        <mxCell id="sender" parent="1" style="swimlane;startSize=30;html=1;whiteSpace=wrap;fillColor=#f0f4fb;strokeColor=#6c8ebf;fontStyle=1;verticalAlign=top;" value="SENDER — ESP32-S3" vertex="1">
