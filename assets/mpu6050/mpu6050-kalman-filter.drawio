<?xml version="1.0" encoding="UTF-8"?>
<mxfile host="drawio" version="26.0.0">
  <diagram name="MPU6050-Kalman-Filter">
    <mxGraphModel dx="1400" dy="820" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" math="1" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="ttl" value="MPU6050 — Kalman Filter · 2-state [ angle θ , gyro-bias b ] per axis" style="text;html=1;align=center;verticalAlign=middle;fontStyle=1;fontSize=18;" vertex="1" parent="1">
          <mxGeometry x="120" y="18" width="1180" height="30" as="geometry" />
        </mxCell>
        <mxCell id="sub" value="gyro predicts the angle · accelerometer corrects it · the filter also learns the slow gyro drift (bias b)" style="text;html=1;align=center;verticalAlign=middle;fontSize=13;fontColor=#555555;" vertex="1" parent="1">
          <mxGeometry x="120" y="50" width="1180" height="24" as="geometry" />
        </mxCell>

        <!-- inputs -->
        <mxCell id="gyroIn" value="&lt;b&gt;Gyroscope&lt;/b&gt;&#xa;\(\omega\) = rate (°/s)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="40" y="215" width="180" height="60" as="geometry" />
        </mxCell>
        <mxCell id="accelIn" value="&lt;b&gt;Accelerometer&lt;/b&gt;&#xa;\(z = \mathrm{atan2}(a)\) — measured angle" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="775" y="70" width="290" height="52" as="geometry" />
        </mxCell>

        <!-- PREDICT -->
        <mxCell id="predict" value="① PREDICT — Time Update (gyro)" style="swimlane;startSize=30;html=1;whiteSpace=wrap;fillColor=none;strokeColor=#2E8B7F;dashed=1;dashPattern=8 6;strokeWidth=2;fontStyle=1;fontSize=14;fontColor=#2E8B7F;verticalAlign=top;align=center;" vertex="1" parent="1">
          <mxGeometry x="280" y="150" width="440" height="205" as="geometry" />
        </mxCell>
        <mxCell id="predictBody" value="\[rate = \omega - b\]\[\theta^{-} = \theta + rate\cdot dt\]\[P^{-} = F\,P\,F^{\top} + Q,\ \ F=\begin{bmatrix}1 &amp; -dt\\ 0 &amp; 1\end{bmatrix}\]" style="text;html=1;align=center;verticalAlign=middle;fontSize=13;" vertex="1" parent="predict">
          <mxGeometry x="10" y="36" width="420" height="160" as="geometry" />
        </mxCell>

        <!-- UPDATE -->
        <mxCell id="update" value="② UPDATE — Measurement Update (accel)" style="swimlane;startSize=30;html=1;whiteSpace=wrap;fillColor=none;strokeColor=#E8862E;dashed=1;dashPattern=8 6;strokeWidth=2;fontStyle=1;fontSize=14;fontColor=#E8862E;verticalAlign=top;align=center;" vertex="1" parent="1">
          <mxGeometry x="775" y="150" width="470" height="270" as="geometry" />
        </mxCell>
        <mxCell id="updateBody" value="\[y = z - \theta^{-}\qquad\text{(innovation)}\]\[S = P^{-}_{00} + R,\qquad K = \tfrac{1}{S}\begin{bmatrix}P^{-}_{00}\\[2pt] P^{-}_{10}\end{bmatrix}\]\[\theta = \theta^{-} + K_0\,y,\quad b = b^{-} + K_1\,y\]\[P = (I - K\,H)\,P^{-},\ \ H=[\,1\ \ 0\,]\]" style="text;html=1;align=center;verticalAlign=middle;fontSize=13;" vertex="1" parent="update">
          <mxGeometry x="10" y="34" width="450" height="228" as="geometry" />
        </mxCell>

        <!-- output (right of Update) -->
        <mxCell id="out" value="&lt;b&gt;State estimate&lt;/b&gt;&#xa;\(\hat\theta\) → fRoll / fPitch&#xa;&#xa;\(\hat b\) = gyro bias&#xa;(drift removed)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="1300" y="215" width="185" height="140" as="geometry" />
        </mxCell>

        <!-- params + source note (lower-left, under Predict) -->
        <mxCell id="params" value="\[Q_\theta = Q_b = 0.003 \qquad R = 0.15 \qquad dt = 4\,\mathrm{ms}\ (250\,\mathrm{Hz})\]" style="text;html=1;align=center;verticalAlign=middle;fontSize=13;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="240" y="500" width="520" height="30" as="geometry" />
        </mxCell>
        <mxCell id="srcNote" value="Runs on 2 axes: fRoll = Kalman(rawR, +ωy, dt) · fPitch = Kalman(rawP, −ωx, dt) − 2° trim" style="text;html=1;align=center;verticalAlign=middle;fontSize=11;fontColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="240" y="532" width="720" height="30" as="geometry" />
        </mxCell>

        <!-- edges -->
        <mxCell id="k_gyro" value="\(\omega\)" style="html=1;fontSize=13;fontStyle=2;labelBackgroundColor=#ffffff;endArrow=classic;strokeColor=#333333;rounded=0;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="gyroIn" target="predict"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="k_accel" value="\(z\)" style="html=1;fontSize=13;fontStyle=2;labelBackgroundColor=#ffffff;endArrow=classic;strokeColor=#333333;rounded=0;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="accelIn" target="update"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="k_prior" value="a priori \(\theta^{-}, P^{-}\)" style="html=1;fontSize=12;fontStyle=2;labelBackgroundColor=#ffffff;endArrow=classic;strokeColor=#333333;rounded=0;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="predict" target="update"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="k_out" value="\(\hat\theta, \hat b\)" style="html=1;fontSize=12;fontStyle=2;labelBackgroundColor=#ffffff;endArrow=classic;strokeColor=#333333;rounded=0;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="update" target="out"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="k_recur" value="a posteriori \(\theta, b, P\)  →  next cycle  (\(z^{-1}\))" style="edgeStyle=orthogonalEdgeStyle;html=1;fontSize=12;fontStyle=2;labelBackgroundColor=#ffffff;endArrow=classic;strokeColor=#9673a6;strokeWidth=2;dashed=1;rounded=0;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=1;entryDx=0;entryDy=0;" edge="1" parent="1" source="update" target="predict">
          <mxGeometry relative="1" as="geometry">
            <Array as="points"><mxPoint x="1010" y="465" /><mxPoint x="500" y="465" /></Array>
          </mxGeometry>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
