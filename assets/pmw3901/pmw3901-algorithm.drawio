        <mxCell id="p4" edge="1" parent="1" source="scale" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" target="integ">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="p5" edge="1" parent="1" source="integ" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" target="gate">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="p6" edge="1" parent="1" source="gate" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;fontSize=11;labelBackgroundColor=#ffffff;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" target="off" value="no">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="p7" edge="1" parent="1" source="gate" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;fontSize=11;labelBackgroundColor=#ffffff;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" target="outer" value="yes">
          <mxGeometry relative="1" as="geometry" />
