<?xml version="1.0" encoding="UTF-8"?>
<mxfile host="drawio" version="26.0.0">
  <diagram name="PMW3901-Position-Hold">
    <mxGraphModel dx="1400" dy="820" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" math="1" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="ttl" value="PMW3901 — Position Hold · Cascade PI–PD (position → velocity → tilt)" style="text;html=1;align=center;verticalAlign=middle;fontStyle=1;fontSize=18;" vertex="1" parent="1">
          <mxGeometry x="120" y="20" width="1200" height="30" as="geometry" />
        </mxCell>

        <!-- nested dashed loop boxes -->
        <mxCell id="outerBox" value="OUTER LOOP — PI (Position):  drives position back to the hold point, sets the target velocity" style="rounded=1;arcSize=4;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#2E8B7F;dashed=1;dashPattern=8 6;strokeWidth=2;verticalAlign=top;align=left;spacingLeft=16;spacingTop=8;fontSize=12;fontStyle=2;fontColor=#2E8B7F;" vertex="1" parent="1">
          <mxGeometry x="165" y="95" width="1170" height="430" as="geometry" />
        </mxCell>
        <mxCell id="innerBox" value="INNER LOOP — PD (Velocity):  tracks the target velocity, output is the tilt-angle command" style="rounded=1;arcSize=5;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#E8862E;dashed=1;dashPattern=8 6;strokeWidth=2;verticalAlign=top;align=left;spacingLeft=16;spacingTop=8;fontSize=12;fontStyle=2;fontColor=#E8862E;" vertex="1" parent="1">
          <mxGeometry x="558" y="122" width="770" height="368" as="geometry" />
        </mxCell>

        <!-- setpoint -->
        <mxCell id="sp" value="\(pos_{target}=0\)&#xa;(hold / stick)" style="text;html=1;align=right;verticalAlign=middle;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="30" y="180" width="140" height="48" as="geometry" />
        </mxCell>

        <!-- Sigma 1 -->
        <mxCell id="sum1" value="Σ" style="ellipse;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#333333;fontSize=18;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="196" y="183" width="42" height="42" as="geometry" />
        </mxCell>
        <mxCell id="sum1p" value="+" style="text;html=1;align=center;fontSize=14;fontStyle=1;fontColor=#2E8B7F;" vertex="1" parent="1"><mxGeometry x="176" y="178" width="16" height="16" as="geometry" /></mxCell>
        <mxCell id="sum1m" value="−" style="text;html=1;align=center;fontSize=15;fontStyle=1;fontColor=#b85450;" vertex="1" parent="1"><mxGeometry x="214" y="226" width="16" height="16" as="geometry" /></mxCell>

        <!-- OUTER PI block -->
        <mxCell id="pOuter" value="&lt;b&gt;PI — Position&lt;/b&gt;&#xa;\(V^{*} = K_p\,e + K_i\!\int e\,dt\)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#333333;fontSize=13;verticalAlign=middle;align=center;" vertex="1" parent="1">
          <mxGeometry x="285" y="172" width="195" height="64" as="geometry" />
        </mxCell>
        <mxCell id="pOuterK" value="\[K_p{=}0.6\,\alpha_h \quad K_i{=}0.008 \quad(V^{*}\!\le\!\pm10)\]" style="text;html=1;align=center;verticalAlign=top;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="245" y="240" width="275" height="26" as="geometry" />
        </mxCell>

        <!-- Sigma 2 -->
        <mxCell id="sum2" value="Σ" style="ellipse;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#333333;fontSize=18;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="590" y="183" width="42" height="42" as="geometry" />
        </mxCell>
        <mxCell id="sum2p" value="+" style="text;html=1;align=center;fontSize=14;fontStyle=1;fontColor=#2E8B7F;" vertex="1" parent="1"><mxGeometry x="570" y="178" width="16" height="16" as="geometry" /></mxCell>
        <mxCell id="sum2m" value="−" style="text;html=1;align=center;fontSize=15;fontStyle=1;fontColor=#b85450;" vertex="1" parent="1"><mxGeometry x="608" y="226" width="16" height="16" as="geometry" /></mxCell>

        <!-- INNER PD block -->
        <mxCell id="pidInner" value="&lt;b&gt;PD — Velocity&lt;/b&gt;&#xa;\(\alpha = K_p\,e_v + K_d\,\dot d\)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#333333;fontSize=13;verticalAlign=middle;align=center;" vertex="1" parent="1">
          <mxGeometry x="680" y="167" width="255" height="74" as="geometry" />
        </mxCell>
        <mxCell id="pidInnerK" value="\[K_p{=}0.25\,\alpha_h \quad K_d{=}0.37\,\alpha_h\;(\text{D LPF})\]" style="text;html=1;align=center;verticalAlign=top;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="655" y="245" width="305" height="26" as="geometry" />
        </mxCell>

        <!-- Plant -->
        <mxCell id="plant" value="&lt;b&gt;Tilt → Airframe&lt;/b&gt;&#xa;roll/pitch setpoint → motion&#xa;(tilt ≤ ±15°)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#eef6f4;strokeColor=#333333;fontSize=13;verticalAlign=middle;align=center;" vertex="1" parent="1">
          <mxGeometry x="1040" y="168" width="235" height="72" as="geometry" />
        </mxCell>

        <!-- feedback: sensor + filter -->
        <mxCell id="sensor" value="&lt;b&gt;PMW3901 (optical flow)&lt;/b&gt;&#xa;readMotionCount @ 10 ms · deltaX, deltaY" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#333333;fontSize=12;verticalAlign=middle;align=center;" vertex="1" parent="1">
          <mxGeometry x="680" y="380" width="255" height="78" as="geometry" />
        </mxCell>
        <mxCell id="fltr" value="&lt;b&gt;Gyro-comp + scale by h&lt;/b&gt;&#xa;\(V_{real}\), integrate → pos (±200 cm)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#333333;fontSize=12;verticalAlign=middle;align=center;" vertex="1" parent="1">
          <mxGeometry x="275" y="380" width="235" height="78" as="geometry" />
        </mxCell>

        <mxCell id="note" value="gate: rc5 high · no stick override · not bouncing · h &gt; 80 mm  (else pos=0, hold off) · out: shared_pwm_opt_x/y → Core 1 adds to targetR / targetP · dt = 4 ms @ 250 Hz" style="text;html=1;align=left;verticalAlign=middle;fontSize=11;fontColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="180" y="490" width="1150" height="30" as="geometry" />
        </mxCell>

        <!-- forward edges -->
        <mxCell id="e_sp" style="html=1;endArrow=classic;strokeColor=#333333;rounded=0;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="sp" target="sum1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e1" value="\(e\) (pos error)" style="html=1;fontSize=13;fontStyle=2;labelBackgroundColor=#ffffff;endArrow=classic;strokeColor=#333333;rounded=0;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="sum1" target="pOuter"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e2" value="\(V^{*}\) (target velocity)" style="html=1;fontSize=13;fontStyle=2;labelBackgroundColor=#ffffff;endArrow=classic;strokeColor=#333333;rounded=0;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="pOuter" target="sum2"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e3" value="\(e_v\)" style="html=1;fontSize=13;fontStyle=2;labelBackgroundColor=#ffffff;endArrow=classic;strokeColor=#333333;rounded=0;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="sum2" target="pidInner"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e4" value="\(\alpha\) tilt (shared_pwm_opt)" style="html=1;fontSize=13;fontStyle=2;labelBackgroundColor=#ffffff;endArrow=classic;strokeColor=#333333;rounded=0;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="pidInner" target="plant"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- feedback edges -->
        <mxCell id="fb_plant" value="actual motion (physical)" style="edgeStyle=orthogonalEdgeStyle;html=1;fontSize=12;fontStyle=2;labelBackgroundColor=#ffffff;endArrow=classic;strokeColor=#333333;rounded=0;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=1;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="plant" target="sensor"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="fb_v" value="\(V_{real}\) (heavy LPF)" style="edgeStyle=orthogonalEdgeStyle;html=1;fontSize=12;fontStyle=2;labelBackgroundColor=#ffffff;endArrow=classic;strokeColor=#333333;rounded=0;exitX=0.72;exitY=0;exitDx=0;exitDy=0;entryX=0.5;entryY=1;entryDx=0;entryDy=0;" edge="1" parent="1" source="sensor" target="sum2"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="fb_flow" value="Δx, Δy · PIXEL_TO_RAD" style="html=1;fontSize=12;fontStyle=2;labelBackgroundColor=#ffffff;endArrow=classic;strokeColor=#333333;rounded=0;exitX=0;exitY=0.5;exitDx=0;exitDy=0;entryX=1;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="sensor" target="fltr"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="fb_pos" value="pos (integrated)" style="edgeStyle=orthogonalEdgeStyle;html=1;fontSize=12;fontStyle=2;labelBackgroundColor=#ffffff;endArrow=classic;strokeColor=#333333;rounded=0;exitX=0;exitY=0.5;exitDx=0;exitDy=0;entryX=0.5;entryY=1;entryDx=0;entryDy=0;" edge="1" parent="1" source="fltr" target="sum1"><mxGeometry relative="1" as="geometry" /></mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
