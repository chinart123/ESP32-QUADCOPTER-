<mxfile host="app.diagrams.net">
  <diagram name="PMW3901-Algorithm" id="0">
    <mxGraphModel dx="1823" dy="1023" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="827" pageHeight="1169" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="title" parent="1" style="text;html=1;align=center;verticalAlign=middle;fontStyle=1;fontSize=17;" value="PMW3901 — Optical-Flow Odometry &amp; Cascaded Position-Hold PID" vertex="1">
          <mxGeometry height="30" width="1080" x="40" y="20" as="geometry" />
        </mxCell>
        <mxCell id="setup" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" value="setupPMW() — SPI init (CS / SCK / MOSI / MISO)" vertex="1">
          <mxGeometry height="50" width="500" x="300" y="60" as="geometry" />
        </mxCell>
        <mxCell id="read" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" value="readMotionCount() every 10 ms&#xa;raw_dx, raw_dy  →  deltaX, deltaY (−raw_dy)" vertex="1">
          <mxGeometry height="60" width="500" x="300" y="150" as="geometry" />
        </mxCell>
        <mxCell id="comp" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" value="Gyro / attitude compensation (remove tilt-induced flow)&#xa;real_angle = flow · PIXEL_TO_RAD + Δattitude · 0.83 (GYRO_COMP)" vertex="1">
          <mxGeometry height="70" width="500" x="300" y="250" as="geometry" />
        </mxCell>
        <mxCell id="scale" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" value="Scale by height → ground velocity&#xa;dx_cm = real_angle · height_cm  (height_cm from filteredHeight)&#xa;V_real = dx_cm / Δt  (heavy LPF)" vertex="1">
          <mxGeometry height="80" width="500" x="300" y="360" as="geometry" />
        </mxCell>
        <mxCell id="integ" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" value="Integrate position:  pos_x += dx_cm,  pos_y += dy_cm  (constrain ±200 cm)" vertex="1">
          <mxGeometry height="50" width="500" x="300" y="480" as="geometry" />
        </mxCell>
        <mxCell id="gate" parent="1" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" value="Pos-Hold enabled?&#xa;rc5 high · no stick override&#xa;· not bouncing · h &gt; 80 mm" vertex="1">
          <mxGeometry height="110" width="260" x="420" y="570" as="geometry" />
        </mxCell>
        <mxCell id="off" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" value="Disabled&#xa;pos_x/y = 0&#xa;shared_pwm_opt = 0&#xa;pos_hold_active = false" vertex="1">
          <mxGeometry height="70" width="230" x="850" y="590" as="geometry" />
        </mxCell>
        <mxCell id="outer" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" value="OUTER loop — position → target velocity&#xa;error = 0 − pos  (dead-zone 0.4 cm)&#xa;iTerm (clamp ±10) → target_V = Kp·error + Ki·iTerm  (±10, ×alt_factor)" vertex="1">
          <mxGeometry height="90" width="500" x="300" y="710" as="geometry" />
        </mxCell>
        <mxCell id="inner" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" value="INNER loop — velocity → tilt angle (PD)&#xa;error_vel = target_V − V_real&#xa;raw_angle = Kp_vel·error_vel + Kd_vel·filtered_d  (D low-pass filtered)" vertex="1">
          <mxGeometry height="90" width="500" x="300" y="840" as="geometry" />
        </mxCell>
        <mxCell id="out" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;" value="shared_pwm_opt_x / _y = constrain(±15°) · shared_pos_hold_active = true&#xa;→ Core 1 adds correction to targetR / targetP" vertex="1">
          <mxGeometry height="60" width="500" x="300" y="970" as="geometry" />
        </mxCell>
        <mxCell id="p1" edge="1" parent="1" source="setup" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" target="read">
          <mxGeometry relative="1" as="geometry" />
